[Unit]
Description=SpotPredator Predator Detection System
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/spotpredator
ExecStart=/home/pi/spotpredator/venv/bin/python src/main.py
Restart=on-failure
RestartSec=10
StartLimitIntervalSec=0

[Install]
WantedBy=multi-user.target
